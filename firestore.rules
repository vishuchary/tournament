rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /tournaments/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /players/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /baseline_games/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /baseline_ratings/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /settings/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
